<context id="fesom">
  <calendar type="Gregorian"/>

  <field_definition  src="./field_def_fesom.xml"/>
  <file_definition   src="./file_def_fesom.xml"/>
  <axis_definition   src="./axis_def_fesom.xml"/>
  <domain_definition src="./domain_def_fesom.xml"/>
  <grid_definition   src="./grid_def_fesom.xml"/>

  <variable_definition>
    <variable_group id="fesom_runtime">
      <variable id="using_server" type="bool">true</variable>
    </variable_group>

    <!-- FESOM diagnostic flags. Override &diag_list namelist values from XML
         via xios_getvar() in io_xios_init (called after setup_model/namelist
         read, before any diag-gated allocation). If a variable is omitted
         here the namelist value stands. -->
    <variable_group id="fesom_diag_flags">
      <variable id="ldiag_solver"      type="bool">false</variable>
      <variable id="lcurt_stress_surf" type="bool">false</variable>
      <variable id="ldiag_curl_vel3"   type="bool">false</variable>
      <variable id="ldiag_Ri"          type="bool">false</variable>
      <variable id="ldiag_TurbFlux"    type="bool">false</variable>
      <variable id="ldiag_salt3D"      type="bool">false</variable>
      <variable id="ldiag_dMOC"        type="bool">false</variable>
      <variable id="ldiag_DVD"         type="bool">false</variable>
      <variable id="ldiag_forc"        type="bool">false</variable>
      <variable id="ldiag_extflds"     type="bool">false</variable>
      <variable id="ldiag_destine"     type="bool">false</variable>
      <variable id="ldiag_ice"         type="bool">false</variable>
      <variable id="ldiag_trflx"       type="bool">true </variable>
      <variable id="ldiag_uvw_sqr"     type="bool">false</variable>
      <variable id="ldiag_trgrd_xyz"   type="bool">false</variable>
      <variable id="ldiag_cmor"        type="bool">true </variable>
    </variable_group>
  </variable_definition>
</context>
